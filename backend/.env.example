# ==========================================================
# Archivo: .env.example
# Descripción:
# Variables de entorno requeridas para ejecutar la API
# de Farmacia Online VidaSalud.
#
# Instrucciones:
# 1. Copie este archivo y renómbrelo como ".env".
# 2. Reemplace los valores de ejemplo por los de su entorno.
# 3. No publique el archivo ".env" en el repositorio.
# ==========================================================

# ----------------------------------------------------------
# Configuración del servidor
# ----------------------------------------------------------

# Puerto donde se ejecutará la API.
PORT=3000

# Entorno de ejecución (development o production).
NODE_ENV=development

# ----------------------------------------------------------
# Base de datos MongoDB Atlas
# ----------------------------------------------------------

# Cadena de conexión a la base de datos.
MONGODB_URI=mongodb+srv://USUARIO:CONTRASENA@CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Nombre de la base de datos.
DB_NAME=farmacia_online

# ----------------------------------------------------------
# Configuración del Frontend
# ----------------------------------------------------------

# Dirección del frontend autorizada para acceder a la API (CORS).
FRONTEND_URL=http://localhost:5173

# ----------------------------------------------------------
# Autenticación JWT
# ----------------------------------------------------------

# Clave utilizada para firmar y validar los tokens JWT.
JWT_SECRET=clave_secreta_de_ejemplo

# ----------------------------------------------------------
# Usuario administrador inicial
# ----------------------------------------------------------

# Nombre del administrador que será creado por el script createAdmin.js.
ADMIN_NAME=Administrador Farmacia

# Correo electrónico del administrador.
ADMIN_EMAIL=admin@farmacia.cl

# Contraseña inicial del administrador.
ADMIN_PASSWORD=contrasena_de_ejemplo

# ----------------------------------------------------------
# Nota
# ----------------------------------------------------------
# Este archivo contiene únicamente valores de ejemplo.
# Las credenciales reales deben almacenarse únicamente
# en el archivo ".env" local o en las variables de entorno
# de la plataforma de despliegue.
